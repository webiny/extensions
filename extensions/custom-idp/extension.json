{
  "$schema": "../../schemas/extension.schema.json",
  "name": "custom-idp",
  "webinyConfigTsx": {
    "imports": [
      {
        "specifier": "CustomIdp",
        "path": "./extensions/customIdp/CustomIdp.js"
      }
    ],
    "component": {
      "name": "CustomIdp",
      "props": {
        "secretKey": "my-secret-key"
      }
    }
  },
  "packageJson": {
    "dependencies": {
      "jsonwebtoken": "^9.0.3",
      "jwt-decode": "^4.0.0"
    },
    "devDependencies": {
      "@types/jsonwebtoken": "9.0.10"
    }
  },
  "additionalNotes": {
    "messages": [
      {
        "text": "This extension requires a %s to be configured in %s.",
        "variables": ["secretKey", "webiny.config.tsx"]
      },
      {
        "text": "Remove the default %s extension from %s, to avoid conflicts.",
        "variables": ["<Cognito />", "webiny.config.tsx"]
      },
      {
        "text": "Learn more about the extension in %s.",
        "variables": ["extensions/customIdp/README.md"]
      }
    ]
  }
}
